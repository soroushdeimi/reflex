{
  "_comment": "Example configuration for Reflex protocol",

  "server": {
    "_comment": "Run on your server machine",
    "log": {
      "loglevel": "info"
    },
    "inbounds": [
      {
        "port": 8557,
        "protocol": "reflex",
        "tag": "reflex-in",
        "settings": {
          "clients": [
            {
              "id": "b831381d-6324-4d53-ad4f-8cda48b30811",
              "email": "user@example.com",
              "policy": "http2-api"
            }
          ],
          "fallbacks": [
            {
              "type": "http",
              "dest": "127.0.0.1:80"
            }
          ]
        }
      }
    ],
    "outbounds": [
      {
        "protocol": "freedom",
        "tag": "direct",
        "settings": {
          "domainStrategy": "UseIP"
        }
      }
    ],
    "routing": {
      "rules": [
        {
          "type": "field",
          "inboundTag": ["reflex-in"],
          "outboundTag": "direct"
        }
      ]
    }
  },

  "client": {
    "_comment": "Run on your local machine",
    "log": {
      "loglevel": "info"
    },
    "inbounds": [
      {
        "port": 10003,
        "protocol": "socks",
        "tag": "socks-in",
        "settings": {
          "udp": false,
          "auth": "noauth"
        }
      },
      {
        "port": 8888,
        "protocol": "http",
        "tag": "http-in",
        "settings": {}
      }
    ],
    "outbounds": [
      {
        "protocol": "reflex",
        "tag": "reflex-out",
        "settings": {
          "vnext": [
            {
              "address": "YOUR_SERVER_IP",
              "port": 8557,
              "user": {
                "id": "b831381d-6324-4d53-ad4f-8cda48b30811",
                "email": "user@example.com",
                "account": {
                  "type": "xray.proxy.reflex.Account",
                  "id": "b831381d-6324-4d53-ad4f-8cda48b30811",
                  "policy": "http2-api"
                }
              }
            }
          ]
        }
      }
    ],
    "routing": {
      "rules": [
        {
          "type": "field",
          "outboundTag": "reflex-out",
          "ip": ["0.0.0.0/0"]
        }
      ]
    }
  },

  "_policies": {
    "_comment": "Available traffic morphing policies",
    "http2-api": "General web browsing and APIs (default)",
    "youtube":   "Video streaming and large downloads",
    "zoom":      "Video calls and real-time communication"
  },

  "_usage": {
    "build":  "cd xray-core && go build -o xray ./main/",
    "server": "./xray-core/xray -c reflex-server-test.json",
    "client": "./xray-core/xray -c reflex-client-test.json",
    "test":   "curl -x socks5://127.0.0.1:10003 http://httpbin.org/ip"
  }
}
