{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "tag": "reflex-in",
      "port": 443,
      "protocol": "reflex",
      "settings": {
        "clients": [
          {
            "id": "YOUR-UUID-HERE",
            "policy": "http2-api"
          }
        ],
        "fallback": { "dest": 80 }
      },
      "sniffing": { "enabled": true }
    }
  ],
  "outbounds": [
    { "tag": "direct", "protocol": "freedom" }
  ],
  "routing": {
    "rules": [
      { "type": "field", "inboundTag": ["reflex-in"], "outboundTag": "direct" }
    ]
  }
}
